# OpenPAVE software-only validation profile.
#
# This profile keeps the full OpenPAVE runtime path active while routing robot
# commands to MockAdapter instead of physical ROS2 hardware.

ROBOT_ADAPTER=mock
ROBOT_IP_ADDRESS=127.0.0.1

UI_MODEL=llava-hf/llava-v1.6-mistral-7b-hf
UI_API_BASE=http://localhost:8000/v1

ROS_DOMAIN_ID=0
RMW_IMPLEMENTATION=rmw_fastrtps_cpp
ROS_SVC_IMAGE=ros:humble
ROS_PUB_IMAGE=puppy-ros2-cli:humble
