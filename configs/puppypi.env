# OpenPAVE PuppyPi physical validation profile.
#
# Start the PuppyPi ROS2 controller and the OpenAI-compatible VLM backend before
# using this profile. Robot commands are routed to the PuppyPi adapter.

ROBOT_ADAPTER=puppypi
ROBOT_IP_ADDRESS=192.168.0.8

UI_MODEL=llava-hf/llava-v1.6-mistral-7b-hf
UI_API_BASE=http://localhost:8000/v1

ROS_DOMAIN_ID=0
RMW_IMPLEMENTATION=rmw_fastrtps_cpp
ROS_SVC_IMAGE=ros:humble
ROS_PUB_IMAGE=puppy-ros2-cli:humble
