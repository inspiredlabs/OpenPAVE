{
  "id": "scene_understanding_camera_v0",
  "version": "0.1",
  "title": "Camera Scene Understanding",
  "stage": "3B",
  "description": "Observation-only scenario for describing the robot environment from a live camera stream.",
  "prompt_ref": "prompts/scene-understanding.json",
  "expected_intents": [],
  "safety_constraints": {
    "physical_robot_motion_allowed": false,
    "must_not_emit_robot_intent": true
  },
  "robot_sensor_endpoint": {
    "type": "ROS2 sensor endpoint",
    "sensors": ["camera"],
    "optional_sensors": ["depth", "lidar", "robot_state"],
    "validated_target": "PuppyPi camera stream"
  },
  "inference_node": {
    "api_contract": "OpenAI-compatible VLM API",
    "default_api_base": "http://localhost:8000/v1",
    "default_model": "llava-hf/llava-v1.6-mistral-7b-hf"
  },
  "adapter": {
    "name": "none",
    "required": false
  },
  "runtime_profile": "configs/mock.env",
  "success_criteria": [
    "The model returns a concise environment description.",
    "No STOP, TROT, MOVE, or HOME command is emitted as robot intent.",
    "The UI shows prompt and result without requiring physical robot motion."
  ]
}
